{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "outDir": "dist",
    "paths": {
      "obsidian": ["./node_modules/obsidian"]
    }
  },
  "include": ["src", "esbuild.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
